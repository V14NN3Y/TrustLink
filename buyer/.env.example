# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# KkiaPay Configuration (https://kkiapay.me)
# Get your API keys from https://admin.kkiapay.me
# PUBLIC_KEY est la clé publique (sûre côté client)
VITE_KKIAPAY_PUBLIC_KEY=your_kkiapay_public_key_here
VITE_KKIAPAY_SANDBOX=true

# Example:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
